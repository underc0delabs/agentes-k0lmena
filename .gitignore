# No versionar lo que generan los agentes, pero conservar las carpetas vacías
/output/**
!/output/
!/output/**/
!/output/**/.gitkeep

# Sistema operativo
.DS_Store
Thumbs.db

# Editores
.idea/
.vscode/*
!.vscode/extensions.json

# Node (por si más adelante se agregan herramientas)
node_modules/
npm-debug.log*

# Variables de entorno / secretos (tokens de MCP, etc.)
.env
.env.local

# Python
__pycache__/
*.pyc
.venv/
venv/

# MCP: NO commitees secretos. El .mcp.json se versiona (Playwright no lleva secretos).
# Para conexiones con token (Jira, Xray, etc.), usá ${VARIABLE} de entorno, nunca el valor real.

# Permisos personales de Claude Code (no se comparten)
.claude/settings.local.json

# Carpeta por defecto de Playwright MCP (capturas/traces sueltas)
.playwright-mcp/

# Logs sueltos
*.log
